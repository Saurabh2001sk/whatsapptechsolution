# =========================
# Server
# =========================
PORT=5000
NODE_ENV=development

# Local frontend for npm run dev
# Production example:
# FRONTEND_URL=https://your-frontend-domain.com
FRONTEND_URL=http://localhost:5173
# Comma-separated extra allowed browser origins, for custom domains or staging.
# Example: https://app.yourdomain.com,https://staging.yourdomain.com
FRONTEND_URLS=

# Use disable only for local PostgreSQL that does not support SSL.
# Remote DB providers usually require SSL.
PGSSL=
PGSSL_REJECT_UNAUTHORIZED=true
AUTO_MIGRATE_ON_START=false

# Local backend public URL
# Production example:
# PUBLIC_BASE_URL=https://your-backend-domain.com
PUBLIC_BASE_URL=http://localhost:5000

# =========================
# Database
# =========================
DATABASE_URL=postgresql://username:password@localhost:5432/bos_whatsapp_sales

# =========================
# Auth
# =========================
# Production me 32+ characters ka strong random secret use karo.
JWT_SECRET=change-this-to-a-long-random-secret-minimum-32-characters

# =========================
# Super Admin Seed
# =========================
# Only for first bootstrap / admin creation.
# Production me strong password use karo and .env ko commit mat karo.
SUPER_ADMIN_NAME=Platform Super Admin
SUPER_ADMIN_EMAIL=superadmin@example.com
SUPER_ADMIN_PASSWORD=change-this-super-admin-password

DEMO_ADMIN_PASSWORD=AdminDemo@12345
DEMO_MANAGER_PASSWORD=ManagerDemo@12345
DEMO_SALES_PASSWORD=SalesDemo@12345

# =========================
# WhatsApp / Meta Webhook
# =========================
WHATSAPP_VERIFY_TOKEN=change-this-custom-webhook-verify-token
WHATSAPP_API_VERSION=v24.0
WHATSAPP_APP_SECRET=your-meta-app-secret

# Optional only for local/demo fallback.
# Final SaaS me client token Embedded Signup ke baad DB me encrypted save hoga.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WABA_ID=
WHATSAPP_TEST_NUMBERS=919999999999

# =========================
# Meta Embedded Signup
# =========================
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_EMBEDDED_SIGNUP_CONFIG_ID=your-embedded-signup-config-id
WHATSAPP_CAMPAIGN_DAILY_LIMIT=1000
WHATSAPP_CAMPAIGN_FAILURE_RATE_LIMIT=0.2
WHATSAPP_CAMPAIGN_QUALITY_MIN_SAMPLE=50

# =========================
# Campaign Queue / Scheduled Sender
# =========================
# Render web service: set REDIS_URL, keep worker flags false.
# Render worker service: use the same backend start command, same Redis URL, and set the needed worker flags true.
REDIS_URL=
RATE_LIMIT_REDIS_URL=
WEBHOOK_REDIS_URL=
WEBHOOK_QUEUE_NAME=webhook-processing
WEBHOOK_WORKER_ENABLED=false
WEBHOOK_WORKER_CONCURRENCY=2
WEBHOOK_JOB_ATTEMPTS=5
OUTBOUND_REDIS_URL=
OUTBOUND_QUEUE_NAME=outbound-retry
OUTBOUND_WORKER_ENABLED=false
OUTBOUND_MESSAGE_MAX_RETRY_ATTEMPTS=5
OUTBOUND_RETRY_SCAN_LIMIT=25
OUTBOUND_RETRY_SCAN_EVERY_MS=60000
CAMPAIGN_REDIS_URL=
CAMPAIGN_QUEUE_NAME=campaign-delivery
CAMPAIGN_WORKER_ENABLED=false
CAMPAIGN_WORKER_CONCURRENCY=1
CAMPAIGN_JOB_ATTEMPTS=3

# =========================
# Production Media Storage
# =========================
# Required in production unless MEDIA_STORAGE_ALLOW_LOCAL_IN_PRODUCTION=true is intentionally set for a temporary test.
MEDIA_STORAGE_DRIVER=s3
MEDIA_STORAGE_BUCKET=
MEDIA_STORAGE_REGION=auto
MEDIA_STORAGE_ENDPOINT=
MEDIA_STORAGE_ACCESS_KEY_ID=
MEDIA_STORAGE_SECRET_ACCESS_KEY=
MEDIA_STORAGE_FORCE_PATH_STYLE=true
MEDIA_STORAGE_ALLOW_LOCAL_IN_PRODUCTION=false
OUTBOUND_MEDIA_MAX_BYTES=16777216

# Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
META_TOKEN_ENCRYPTION_KEY=your-64-character-hex-key

# =========================
# PostgreSQL Optional Tuning
# =========================
PG_POOL_MAX=10
PG_IDLE_TIMEOUT_MS=30000
PG_CONNECTION_TIMEOUT_MS=5000
PG_QUERY_TIMEOUT_MS=15000
PG_STATEMENT_TIMEOUT_MS=15000
