{
  "name": "api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "tsc -p tsconfig.json",
    "promote:platform-admin": "ts-node src/scripts/promote-platform-admin.ts",
    "start": "node dist/main.js",
    "start:campaign-worker": "node dist/workers/campaign-worker.js",
    "start:drip-worker": "node dist/workers/drip-worker.js",
    "start:dev:campaign-worker": "ts-node-dev --respawn --transpile-only src/workers/campaign-worker.ts",
    "start:dev:drip-worker": "ts-node-dev --respawn --transpile-only src/workers/drip-worker.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:status": "prisma migrate status",
    "test": "node --test tests/*.test.mjs",
    "db:backup": "node src/scripts/db-backup.mjs",
    "db:restore": "node src/scripts/db-restore.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1078.0",
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-express": "^11.1.27",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sentry/node": "^10.63.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.79.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^9.0.1",
    "otplib": "^13.4.1",
    "pg": "^8.21.0",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.3",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "prisma": "^7.8.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "@hono/node-server": "1.19.13",
    "multer": "2.2.0"
  }
}
