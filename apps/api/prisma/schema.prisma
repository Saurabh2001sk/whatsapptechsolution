generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                   User[]
  contacts                Contact[]
  contactTypes            ContactType[]
  metaAccounts            TenantMetaAccount[]
  templates               WhatsappTemplate[]
  mediaFiles              MediaFile[]
  campaigns               Campaign[]
  campaignAuditLogs       CampaignAuditLog[]
  dripWorkflows           DripWorkflow[]
  dripEnrollments         DripEnrollment[]
  dripMessages            DripMessage[]
  dripAuditLogs           DripAuditLog[]
  webhookEvents           WebhookEvent[]
  conversations           Conversation[]
  whatsappMessages        WhatsappMessage[]
  conversationAssignments ConversationAssignment[]
  subscriptions           TenantSubscription[]
  usageRecords            TenantUsage[]

  @@map("tenants")
}

model User {
  id                       String          @id @default(uuid())
  tenantId                 String
  email                    String          @unique
  passwordHash             String
  name                     String
  role                     String          @default("admin")
  isActive                 Boolean         @default(true)
  emailVerifiedAt          DateTime?
  twoFactorEnabled         Boolean         @default(false)
  twoFactorSecretEncrypted String?
  twoFactorConfirmedAt     DateTime?
  twoFactorLastUsedAt      DateTime?
  sessionVersion           Int             @default(0)
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt
  trustedDevices           TrustedDevice[]

  tenant                         Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campaignAuditLogs              CampaignAuditLog[]
  dripAuditLogs                  DripAuditLog[]
  passwordResetTokens            PasswordResetToken[]
  emailVerificationTokens        EmailVerificationToken[]
  twoFactorLoginChallenges       TwoFactorLoginChallenge[]
  twoFactorBackupCodes           TwoFactorBackupCode[]
  assignedConversations          Conversation[]            @relation("ConversationAssignedUser")
  sentWhatsappMessages           WhatsappMessage[]         @relation("WhatsappMessageSender")
  conversationAssignments        ConversationAssignment[]  @relation("ConversationAssignedUserHistory")
  conversationAssignmentsCreated ConversationAssignment[]  @relation("ConversationAssignedByUser")

  @@index([tenantId])
  @@map("users")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("email_verification_tokens")
}

model TwoFactorLoginChallenge {
  id             String    @id @default(cuid())
  userId         String
  tokenHash      String    @unique
  expiresAt      DateTime
  usedAt         DateTime?
  failedAttempts Int       @default(0)
  lockedAt       DateTime?
  createdAt      DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("two_factor_login_challenges")
}

model TwoFactorBackupCode {
  id        String    @id @default(cuid())
  userId    String
  codeHash  String
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([usedAt])
  @@map("two_factor_backup_codes")
}

model TrustedDevice {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  userAgent  String?
  ipAddress  String?
  lastUsedAt DateTime?
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("trusted_devices")
}

model ContactType {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  color     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contacts      Contact[]
  campaigns     Campaign[]
  dripWorkflows DripWorkflow[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("contact_types")
}

model Contact {
  id            String    @id @default(uuid())
  tenantId      String
  contactTypeId String?
  name          String
  phone         String
  email         String?
  tags          String[]  @default([])
  optedIn       Boolean   @default(false)
  optInSource   String?
  optInAt       DateTime?
  optOutAt      DateTime?
  createdAt     DateTime  @default(now())
  deletedAt     DateTime?
  updatedAt     DateTime  @updatedAt

  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contactType        ContactType?        @relation(fields: [contactTypeId], references: [id], onDelete: SetNull)
  campaignRecipients CampaignRecipient[]
  dripEnrollments    DripEnrollment[]
  dripMessages       DripMessage[]
  conversations      Conversation[]
  whatsappMessages   WhatsappMessage[]

  @@unique([tenantId, phone])
  @@index([tenantId])
  @@index([contactTypeId])
  @@map("contacts")
}

model TenantMetaAccount {
  id                   String    @id @default(uuid())
  tenantId             String
  metaAppId            String?
  wabaId               String
  phoneNumberId        String    @unique
  businessName         String?
  encryptedAccessToken String
  tokenLastUpdatedAt   DateTime  @default(now())
  qualityRating        String?
  messagingLimitTier   String?
  qualitySyncedAt      DateTime?
  isActive             Boolean   @default(true)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversations Conversation[]

  @@unique([tenantId, wabaId])
  @@index([tenantId])
  @@map("tenant_meta_accounts")
}

model WhatsappTemplate {
  id                String    @id @default(uuid())
  tenantId          String
  metaTemplateId    String?
  name              String
  language          String
  category          String
  status            String    @default("DRAFT")
  headerType        String?
  headerText        String?
  headerMediaFileId String?
  metaHeaderHandle  String?
  bodyText          String
  footerText        String?
  buttons           Json?
  components        Json
  variableCount     Int       @default(0)
  qualityScore      String?
  rejectedReason    String?
  lastSyncedAt      DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  tenant          Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  headerMediaFile MediaFile? @relation(fields: [headerMediaFileId], references: [id], onDelete: SetNull)
  campaigns       Campaign[]
  dripSteps       DripStep[]

  @@unique([tenantId, name, language])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, category])
  @@index([headerMediaFileId])
  @@map("whatsapp_templates")
}

model Campaign {
  id                        String    @id @default(uuid())
  tenantId                  String
  templateId                String
  contactTypeId             String?
  name                      String
  audienceType              String
  status                    String    @default("DRAFT")
  variableValues            Json?
  totalRecipients           Int       @default(0)
  sentCount                 Int       @default(0)
  failedCount               Int       @default(0)
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt
  startedAt                 DateTime?
  completedAt               DateTime?
  scheduledAt               DateTime?
  canceledAt                DateTime?
  lastError                 String?
  metaHeaderMediaId         String?
  metaHeaderMediaUploadedAt DateTime?

  tenant      Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  template    WhatsappTemplate    @relation(fields: [templateId], references: [id], onDelete: Restrict)
  contactType ContactType?        @relation(fields: [contactTypeId], references: [id], onDelete: SetNull)
  recipients  CampaignRecipient[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, status, scheduledAt])
  @@index([templateId])
  @@index([contactTypeId])
  @@map("campaigns")
}

model CampaignRecipient {
  id              String    @id @default(uuid())
  tenantId        String
  campaignId      String
  contactId       String
  phone           String
  status          String    @default("PENDING")
  metaMessageId   String?
  errorMessage    String?
  sentAt          DateTime?
  deliveredAt     DateTime?
  readAt          DateTime?
  failedAt        DateTime?
  statusWebhookAt DateTime?
  retryCount      Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact  Contact  @relation(fields: [contactId], references: [id], onDelete: Restrict)

  @@unique([campaignId, contactId])
  @@index([tenantId])
  @@index([campaignId])
  @@index([contactId])
  @@index([tenantId, status])
  @@index([metaMessageId])
  @@map("campaign_recipients")
}

model CampaignAuditLog {
  id          String   @id @default(uuid())
  tenantId    String
  campaignId  String?
  actorUserId String?
  action      String
  metadata    Json?
  createdAt   DateTime @default(now())

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actorUser User?  @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, campaignId])
  @@index([tenantId, action])
  @@index([actorUserId])
  @@map("campaign_audit_logs")
}

model DripWorkflow {
  id                      String    @id @default(uuid())
  tenantId                String
  targetContactTypeId     String?
  name                    String
  description             String?
  status                  String    @default("DRAFT")
  audienceType            String    @default("ALL_OPTED_IN")
  timezone                String    @default("Asia/Kolkata")
  sendingStartTime        String    @default("09:00")
  sendingEndTime          String    @default("19:00")
  sendingDays             Int[]     @default([1, 2, 3, 4, 5, 6])
  autoEnrollNewContacts   Boolean   @default(true)
  autoEnrollInbound       Boolean   @default(true)
  includeExistingContacts Boolean   @default(false)
  allowReentry            Boolean   @default(false)
  reentryCooldownDays     Int?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  activatedAt             DateTime?
  pausedAt                DateTime?
  archivedAt              DateTime?

  tenant            Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  targetContactType ContactType?     @relation(fields: [targetContactTypeId], references: [id], onDelete: SetNull)
  steps             DripStep[]
  enrollments       DripEnrollment[]
  messages          DripMessage[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, targetContactTypeId])
  @@map("drip_workflows")
}

model DripStep {
  id                        String    @id @default(uuid())
  tenantId                  String
  workflowId                String
  templateId                String
  name                      String
  dayOffset                 Int
  minuteOffset              Int       @default(0)
  position                  Int
  variableValues            Json?
  isActive                  Boolean   @default(true)
  metaHeaderMediaId         String?
  metaHeaderMediaUploadedAt DateTime?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  workflow DripWorkflow     @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  template WhatsappTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict)
  messages DripMessage[]

  @@unique([workflowId, position])
  @@index([tenantId])
  @@index([tenantId, workflowId])
  @@index([templateId])
  @@map("drip_steps")
}

model DripEnrollment {
  id                  String    @id @default(uuid())
  tenantId            String
  workflowId          String
  contactId           String
  status              String    @default("ACTIVE")
  source              String
  currentStepPosition Int       @default(0)
  enrolledAt          DateTime  @default(now())
  nextRunAt           DateTime?
  lastProcessedAt     DateTime?
  completedAt         DateTime?
  pausedAt            DateTime?
  stoppedAt           DateTime?
  stopReason          String?
  entryCount          Int       @default(1)
  enrollmentCycle     Int       @default(1)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  tenant   Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workflow DripWorkflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  contact  Contact       @relation(fields: [contactId], references: [id], onDelete: Restrict)
  messages DripMessage[]

  @@unique([workflowId, contactId, enrollmentCycle])
  @@index([tenantId])
  @@index([tenantId, workflowId, contactId, status])
  @@index([tenantId, status])
  @@index([tenantId, nextRunAt])
  @@index([workflowId])
  @@index([contactId])
  @@map("drip_enrollments")
}

model DripMessage {
  id              String    @id @default(uuid())
  tenantId        String
  workflowId      String
  enrollmentId    String
  stepId          String
  contactId       String
  status          String    @default("PENDING")
  metaMessageId   String?
  errorMessage    String?
  retryCount      Int       @default(0)
  scheduledFor    DateTime
  sentAt          DateTime?
  deliveredAt     DateTime?
  readAt          DateTime?
  failedAt        DateTime?
  statusWebhookAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant     Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workflow   DripWorkflow   @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  enrollment DripEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  step       DripStep       @relation(fields: [stepId], references: [id], onDelete: Restrict)
  contact    Contact        @relation(fields: [contactId], references: [id], onDelete: Restrict)

  @@unique([enrollmentId, stepId])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, scheduledFor])
  @@index([workflowId])
  @@index([contactId])
  @@index([metaMessageId])
  @@map("drip_messages")
}

model DripAuditLog {
  id          String   @id @default(uuid())
  tenantId    String
  workflowId  String?
  contactId   String?
  actorUserId String?
  action      String
  metadata    Json?
  createdAt   DateTime @default(now())

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actorUser User?  @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, workflowId])
  @@index([tenantId, contactId])
  @@index([tenantId, action])
  @@index([actorUserId])
  @@map("drip_audit_logs")
}

model WebhookEvent {
  id             String    @id @default(cuid())
  tenantId       String?
  source         String    @default("META")
  status         String    @default("RECEIVED")
  metaObject     String?
  phoneNumberId  String?
  payload        Json
  processedCount Int       @default(0)
  syncedCount    Int       @default(0)
  ignoredCount   Int       @default(0)
  replayCount    Int       @default(0)
  lastError      String?
  lastReplayedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant           Tenant?           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  whatsappMessages WhatsappMessage[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([phoneNumberId])
  @@index([createdAt])
  @@map("webhook_events")
}

model Conversation {
  id                 String    @id @default(uuid())
  tenantId           String
  contactId          String?
  metaAccountId      String
  customerPhone      String
  assignedUserId     String?
  status             String    @default("OPEN")
  unreadCount        Int       @default(0)
  lastMessagePreview String?
  lastMessageAt      DateTime?
  lastInboundAt      DateTime?
  lastOutboundAt     DateTime?
  resolvedAt         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  tenant       Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact      Contact?                 @relation(fields: [contactId], references: [id], onDelete: SetNull)
  metaAccount  TenantMetaAccount        @relation(fields: [metaAccountId], references: [id], onDelete: Restrict)
  assignedUser User?                    @relation("ConversationAssignedUser", fields: [assignedUserId], references: [id], onDelete: SetNull)
  messages     WhatsappMessage[]
  assignments  ConversationAssignment[]

  @@unique([tenantId, customerPhone, metaAccountId])
  @@index([tenantId, status, lastMessageAt])
  @@index([tenantId, assignedUserId, status])
  @@index([tenantId, contactId])
  @@map("conversations")
}

model WhatsappMessage {
  id                   String    @id @default(uuid())
  tenantId             String
  conversationId       String
  contactId            String?
  customerPhone        String
  webhookEventId       String?
  mediaFileId          String?
  sentByUserId         String?
  metaMessageId        String?   @unique
  idempotencyKey       String?
  direction            String
  messageType          String
  status               String
  bodyText             String?
  caption              String?
  replyToMetaMessageId String?
  rawPayload           Json?
  errorCode            String?
  errorMessage         String?
  occurredAt           DateTime
  sentAt               DateTime?
  deliveredAt          DateTime?
  readAt               DateTime?
  failedAt             DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  contact      Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)
  webhookEvent WebhookEvent? @relation(fields: [webhookEventId], references: [id], onDelete: SetNull)
  mediaFile    MediaFile?    @relation(fields: [mediaFileId], references: [id], onDelete: SetNull)
  sentByUser   User?         @relation("WhatsappMessageSender", fields: [sentByUserId], references: [id], onDelete: SetNull)

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, conversationId, occurredAt])
  @@index([tenantId, customerPhone, occurredAt])
  @@index([tenantId, contactId, occurredAt])
  @@index([tenantId, status])
  @@index([webhookEventId])
  @@map("whatsapp_messages")
}

model ConversationAssignment {
  id               String    @id @default(uuid())
  tenantId         String
  conversationId   String
  assignedUserId   String?
  assignedByUserId String?
  assignedAt       DateTime  @default(now())
  unassignedAt     DateTime?
  createdAt        DateTime  @default(now())

  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  assignedUser   User?        @relation("ConversationAssignedUserHistory", fields: [assignedUserId], references: [id], onDelete: SetNull)
  assignedByUser User?        @relation("ConversationAssignedByUser", fields: [assignedByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, conversationId, assignedAt])
  @@index([tenantId, assignedUserId, unassignedAt])
  @@map("conversation_assignments")
}

enum BillingResponsibility {
  CUSTOMER_META_BILLING
  PLATFORM_INVOICE
}

enum PaymentProofStatus {
  NOT_REQUIRED
  PENDING_PROOF
  PENDING_VERIFICATION
  VERIFIED
  REJECTED
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
  PENDING_APPROVAL
}

model Plan {
  id                            String   @id @default(uuid())
  code                          String   @unique
  name                          String
  description                   String?
  priceMonthlyPaise             Int      @default(0)
  currency                      String   @default("INR")
  monthlyCampaignRecipientLimit Int
  monthlyCampaignLimit          Int
  maxContacts                   Int
  maxTeamUsers                  Int
  maxAutomationRules            Int      @default(0)
  mediaStorageMb                Int      @default(500)
  supportLevel                  String   @default("standard")
  isActive                      Boolean  @default(true)
  requiresApproval              Boolean  @default(false)
  sortOrder                     Int      @default(0)
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt

  subscriptions TenantSubscription[]

  @@index([isActive])
  @@index([sortOrder])
  @@map("plans")
}

model TenantSubscription {
  id                      String                @id @default(uuid())
  tenantId                String
  planId                  String
  status                  SubscriptionStatus    @default(TRIAL)
  billingResponsibility   BillingResponsibility @default(CUSTOMER_META_BILLING)
  currentPeriodStart      DateTime
  currentPeriodEnd        DateTime
  trialEndsAt             DateTime?
  canceledAt              DateTime?
  paymentProofStatus      PaymentProofStatus    @default(NOT_REQUIRED)
  paymentReference        String?
  paymentPayerName        String?
  paymentAmountPaise      Int?
  paymentProofNote        String?
  paymentSubmittedAt      DateTime?
  paymentVerifiedAt       DateTime?
  paymentRejectedAt       DateTime?
  paymentAdminNote        String?
  paymentVerifiedByUserId String?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan   Plan   @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([planId])
  @@index([status])
  @@index([paymentProofStatus])
  @@index([currentPeriodStart, currentPeriodEnd])
  @@map("tenant_subscriptions")
}

model TenantUsage {
  id                        String   @id @default(uuid())
  tenantId                  String
  periodStart               DateTime
  periodEnd                 DateTime
  campaignsCreated          Int      @default(0)
  campaignRecipientsPlanned Int      @default(0)
  campaignRecipientsSent    Int      @default(0)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, periodStart, periodEnd])
  @@index([tenantId])
  @@index([periodStart, periodEnd])
  @@map("tenant_usage")
}

model MediaFile {
  id           String   @id @default(uuid())
  tenantId     String
  originalName String
  storedName   String
  mimeType     String
  sizeBytes    Int
  mediaType    String
  storageKey   String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant                Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  templateHeaderSamples WhatsappTemplate[]
  whatsappMessages      WhatsappMessage[]

  @@index([tenantId])
  @@index([tenantId, mediaType])
  @@map("media_files")
}

model NotificationLog {
  id             String   @id @default(cuid())
  tenantId       String?
  event          String
  channel        String   @default("email")
  recipientEmail String
  subject        String
  status         String
  error          String?
  metadata       Json?
  createdAt      DateTime @default(now())

  @@index([tenantId])
  @@index([event])
  @@index([status])
  @@index([createdAt])
  @@map("notification_logs")
}

model BillingAuditLog {
  id          String   @id @default(cuid())
  tenantId    String?
  actorUserId String?
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([tenantId])
  @@index([actorUserId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String?
  actorUserId String?
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([tenantId])
  @@index([actorUserId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
